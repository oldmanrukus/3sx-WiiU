# =============================================================================
# 3SX — Wii U Build (TARGET_WIIU)
# =============================================================================

cmake_minimum_required(VERSION 3.24)
project(3sx-wiiu LANGUAGES C)

set(CMAKE_C_STANDARD 11)
set(CMAKE_C_STANDARD_REQUIRED ON)

# Fix "Argument list too long" on MSYS2
set(CMAKE_C_USE_RESPONSE_FILE_FOR_OBJECTS ON)
set(CMAKE_C_USE_RESPONSE_FILE_FOR_LIBRARIES ON)
set(CMAKE_C_USE_RESPONSE_FILE_FOR_INCLUDES ON)
set(CMAKE_C_RESPONSE_FILE_LINK_FLAG "@")
set(CMAKE_NINJA_FORCE_RESPONSE_FILE ON)

# =============================================================================
# Include paths — MSYS2 cygpath conversion
# =============================================================================

find_program(CYGPATH_EXE cygpath)

if(CYGPATH_EXE)
    execute_process(COMMAND ${CYGPATH_EXE} -m "${PROJECT_SOURCE_DIR}/src"
                    OUTPUT_VARIABLE INC_SRC OUTPUT_STRIP_TRAILING_WHITESPACE)
    execute_process(COMMAND ${CYGPATH_EXE} -m "${PROJECT_SOURCE_DIR}/include"
                    OUTPUT_VARIABLE INC_INCLUDE OUTPUT_STRIP_TRAILING_WHITESPACE)
    execute_process(COMMAND ${CYGPATH_EXE} -m "${PROJECT_SOURCE_DIR}/include/sdk"
                    OUTPUT_VARIABLE INC_SDK OUTPUT_STRIP_TRAILING_WHITESPACE)
    execute_process(COMMAND ${CYGPATH_EXE} -m "$ENV{DEVKITPRO}/portlibs/ppc/include"
                    OUTPUT_VARIABLE INC_PORTLIBS OUTPUT_STRIP_TRAILING_WHITESPACE)
    execute_process(COMMAND ${CYGPATH_EXE} -m "$ENV{DEVKITPRO}/wut/include"
                    OUTPUT_VARIABLE INC_WUT OUTPUT_STRIP_TRAILING_WHITESPACE)
    execute_process(COMMAND ${CYGPATH_EXE} -m "$ENV{DEVKITPRO}/devkitPPC/powerpc-eabi/include"
                    OUTPUT_VARIABLE INC_DKP OUTPUT_STRIP_TRAILING_WHITESPACE)
    execute_process(COMMAND ${CYGPATH_EXE} -m "$ENV{DEVKITPRO}/portlibs/ppc/lib/libz.a"
                    OUTPUT_VARIABLE ZLIB_PATH OUTPUT_STRIP_TRAILING_WHITESPACE)
else()
    set(INC_SRC      "${PROJECT_SOURCE_DIR}/src")
    set(INC_INCLUDE  "${PROJECT_SOURCE_DIR}/include")
    set(INC_SDK      "${PROJECT_SOURCE_DIR}/include/sdk")
    set(INC_PORTLIBS "$ENV{DEVKITPRO}/portlibs/ppc/include")
    set(INC_WUT      "$ENV{DEVKITPRO}/wut/include")
    set(INC_DKP      "$ENV{DEVKITPRO}/devkitPPC/powerpc-eabi/include")
    set(ZLIB_PATH    "$ENV{DEVKITPRO}/portlibs/ppc/lib/libz.a")
endif()

set(RAW_INCLUDE_FLAGS
    "-I${INC_SRC}"
    "-I${INC_INCLUDE}"
    "-I${INC_SDK}"
    "-I${INC_PORTLIBS}"
    "-isystem${INC_WUT}"
    "-isystem${INC_DKP}"
)

# =============================================================================
# Source collection
# =============================================================================

file(GLOB_RECURSE GAME_SRC
    src/sf33rd/*.c
    src/arcade/*.c
    src/rendering/*.c
    src/bin2obj/*.c
    src/stb/*.c
    src/argparse/*.c
    src/port/sdk/*.c
    src/port/config/*.c
    src/port/wiiu/*.c
    src/args.c
)

list(FILTER GAME_SRC EXCLUDE REGEX ".*/src/port/config/keymap\\.c$")
list(FILTER GAME_SRC EXCLUDE REGEX ".*/src/port/sdl/.*")

list(APPEND GAME_SRC
    src/port/io/afs_wiiu.c
    src/port/sound/spu_wiiu.c
    src/port/sound/adx_wiiu.c
    src/port/sound/emlShim.c
    src/port/paths_wiiu.c
    src/port/resources_wiiu.c
    src/port/utils.c
)

# =============================================================================
# Static library
# =============================================================================

add_library(3sx-core STATIC ${GAME_SRC})

target_compile_definitions(3sx-core PRIVATE
    TARGET_WIIU
    __WIIU__
    __WUT__
    _POSIX_C_SOURCE
    MEMCARD_DISABLED
    NETPLAY_STUB
)

target_compile_options(3sx-core PRIVATE
    ${RAW_INCLUDE_FLAGS}
    -Wall
    -fno-strict-aliasing
    -Wno-unused-function
    -Wno-unused-variable
    -Wno-unused-but-set-variable
    -Wno-pointer-sign
    -Wno-parentheses
    -Wno-incompatible-pointer-types
    -Wno-discarded-qualifiers
    -Wno-format-overflow
    -Wno-comment
    -Wno-maybe-uninitialized
    -Wno-array-bounds
    -Wno-aggressive-loop-optimizations
    -Wno-stringop-overflow
    -Wno-restrict
    -Wno-stringop-truncation
)

# =============================================================================
# Executable
# =============================================================================

add_executable(3sx-wiiu src/main.c)

target_compile_definitions(3sx-wiiu PRIVATE
    TARGET_WIIU
    __WIIU__
    __WUT__
    _POSIX_C_SOURCE
    MEMCARD_DISABLED
    NETPLAY_STUB
)

target_compile_options(3sx-wiiu PRIVATE
    ${RAW_INCLUDE_FLAGS}
)

# Import zlib as a proper library target — avoids MSYS2 path issues
# and ensures correct link order (after 3sx-core that references it)
add_library(zlib_imported STATIC IMPORTED)
set_target_properties(zlib_imported PROPERTIES IMPORTED_LOCATION "${ZLIB_PATH}")

set(WUT_ROOT $ENV{DEVKITPRO}/wut)

target_link_libraries(3sx-wiiu PRIVATE
    3sx-core
    wut
    zlib_imported
    m
)

wiiu_create_rpx(3sx-wiiu)
